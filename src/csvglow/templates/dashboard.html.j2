<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>csvglow — {{ filename }}</title>
    <style>
        {% include "macros/styles.j2" %}
    </style>
</head>
<body>
    <div class="dashboard-container">

        {# ── Header ────────────────────────────────────────────────── #}
        <div class="dashboard-header">
            <h1>{{ filename }}</h1>
            <p class="subtitle">Generated by csvglow</p>
        </div>

        {# ── Summary Stats ─────────────────────────────────────────── #}
        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-value">{{ "{:,}".format(analysis.row_count) }}</div>
                <div class="stat-label">Rows</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ analysis.column_count }}</div>
                <div class="stat-label">Columns</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ numeric_count }}</div>
                <div class="stat-label">Numeric</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ categorical_count }}</div>
                <div class="stat-label">Categorical</div>
            </div>
            <div class="stat-card">
                <div class="stat-value">{{ datetime_count }}</div>
                <div class="stat-label">Date/Time</div>
            </div>
            {% if missing_pct > 0 %}
            <div class="stat-card">
                <div class="stat-value">{{ "%.1f"|format(missing_pct) }}%</div>
                <div class="stat-label">Missing Values</div>
            </div>
            {% endif %}
        </div>

        {# ── Column Type Badges ────────────────────────────────────── #}
        <div class="type-badges">
            {% for col in analysis.columns %}
            <span class="type-badge {{ col.dtype }}">{{ col.name }}</span>
            {% endfor %}
        </div>

        {# ── Key Insights ──────────────────────────────────────────── #}
        {% if analysis.insights %}
        <div class="insights-section">
            <h2 class="section-title">Key Insights</h2>
            <div class="insights-grid">
                {% for insight in analysis.insights %}
                <div class="insight-card {{ insight.severity }}">
                    <span class="insight-icon">{{ insight.icon }}</span>
                    <span class="insight-text">{{ insight.text }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
        {% endif %}

        {# ── Numeric Distributions ─────────────────────────────────── #}
        {% set histograms = charts | selectattr("chart_type", "equalto", "histogram") | list %}
        {% if histograms %}
        <h2 class="section-title">Numeric Distributions</h2>
        <div class="charts-grid">
            {% for chart in histograms %}
            <div class="chart-card">
                <div class="chart-card::before"></div>
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                {% if chart.stats %}
                <div class="chart-with-stats">
                    <div class="chart-area" id="{{ chart.chart_id }}"></div>
                    <dl class="column-stats">
                        <dt>Mean</dt><dd>{{ chart.stats.mean }}</dd>
                        <dt>Median</dt><dd>{{ chart.stats.median }}</dd>
                        <dt>Std Dev</dt><dd>{{ chart.stats.std }}</dd>
                        <dt>Min</dt><dd>{{ chart.stats.min }}</dd>
                        <dt>Max</dt><dd>{{ chart.stats.max }}</dd>
                        <dt>Q1 / Q3</dt><dd>{{ chart.stats.q25 }} / {{ chart.stats.q75 }}</dd>
                        {% if chart.outlier_count %}
                        <dt></dt><dd><span class="outlier-badge">{{ chart.outlier_count }} outliers</span></dd>
                        {% endif %}
                    </dl>
                </div>
                {% else %}
                <div class="chart-area" id="{{ chart.chart_id }}"></div>
                {% endif %}
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Categorical Breakdowns ────────────────────────────────── #}
        {% set bars = charts | selectattr("chart_type", "equalto", "bar") | list %}
        {% if bars %}
        <h2 class="section-title">Categorical Breakdowns</h2>
        <div class="charts-grid">
            {% for chart in bars %}
            <div class="chart-card">
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                <div class="chart-area" id="{{ chart.chart_id }}"></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Cross Analysis (Crosstabs) ─────────────────────────────── #}
        {% set crosstabs = charts | selectattr("chart_type", "equalto", "crosstab") | list %}
        {% if crosstabs %}
        <h2 class="section-title">Cross Analysis</h2>
        <div class="charts-grid">
            {% for chart in crosstabs %}
            <div class="chart-card">
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                {% if chart.description %}
                <p class="chart-description">{{ chart.description }}</p>
                {% endif %}
                <div class="chart-area" id="{{ chart.chart_id }}"></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Time Series ───────────────────────────────────────────── #}
        {% set lines = charts | selectattr("chart_type", "equalto", "line") | list %}
        {% if lines %}
        <h2 class="section-title">Time Series</h2>
        <div class="charts-grid">
            {% for chart in lines %}
            <div class="chart-card full-width">
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                <div class="chart-area" id="{{ chart.chart_id }}"></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Correlation Heatmap ───────────────────────────────────── #}
        {% set heatmaps = charts | selectattr("chart_type", "equalto", "heatmap") | list %}
        {% if heatmaps %}
        <h2 class="section-title">Correlations</h2>
        <div class="charts-grid">
            {% for chart in heatmaps %}
            <div class="chart-card full-width">
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                <div class="chart-area tall" id="{{ chart.chart_id }}"></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Scatter Plots ─────────────────────────────────────────── #}
        {% set scatters = charts | selectattr("chart_type", "equalto", "scatter") | list %}
        {% if scatters %}
        <h2 class="section-title">Correlated Pairs</h2>
        <div class="charts-grid">
            {% for chart in scatters %}
            <div class="chart-card">
                <div class="chart-header">
                    <span class="chart-title">{{ chart.title }}</span>
                    <button class="copy-btn" onclick="copyChart('{{ chart.chart_id }}', this)">Copy</button>
                </div>
                <div class="chart-area" id="{{ chart.chart_id }}"></div>
            </div>
            {% endfor %}
        </div>
        {% endif %}

        {# ── Data Table ────────────────────────────────────────────── #}
        {% if data_table_json %}
        <h2 class="section-title">Data Preview <span style="font-size:12px;color:var(--text-sub);font-weight:400">(first {{ table_row_count }} rows)</span></h2>
        <input type="text" class="table-filter" id="tableFilter" placeholder="Filter rows..." oninput="filterTable()">
        <div class="table-container" style="max-height:500px;overflow-y:auto;">
            <table class="data-table" id="dataTable">
                <thead>
                    <tr>
                        {% for col in table_columns %}
                        <th onclick="sortTable({{ loop.index0 }})">{{ col }}<span class="sort-arrow">↕</span></th>
                        {% endfor %}
                    </tr>
                </thead>
                <tbody id="tableBody"></tbody>
            </table>
        </div>
        {% endif %}

        {# ── Footer ────────────────────────────────────────────────── #}
        <div class="dashboard-footer">
            Generated by <a href="https://github.com/ratnaditya-j/csvglow" target="_blank">csvglow</a>
        </div>

    </div>

    {# ── ECharts Library ───────────────────────────────────────────── #}
    <script>{{ echarts_js }}</script>

    {# ── Chart Initialization ──────────────────────────────────────── #}
    <script>
    (function() {
        const chartConfigs = {{ charts_json }};
        const chartInstances = {};

        // Initialize all charts
        chartConfigs.forEach(function(config) {
            const dom = document.getElementById(config.chart_id);
            if (!dom) return;
            const chart = echarts.init(dom, null, { renderer: 'svg' });
            chart.setOption(config.option);
            chartInstances[config.chart_id] = chart;
        });

        // Responsive resize
        window.addEventListener('resize', function() {
            Object.values(chartInstances).forEach(function(c) { c.resize(); });
        });

        // Copy chart as PNG to clipboard
        window.copyChart = async function(chartId, btn) {
            const chart = chartInstances[chartId];
            if (!chart) return;

            try {
                // Get chart option and re-render on a hidden canvas
                const opt = chart.getOption();
                const dom = document.getElementById(chartId);
                const rect = dom.getBoundingClientRect();

                const offscreen = document.createElement('div');
                offscreen.style.cssText = 'position:fixed;left:-9999px;top:0;width:' + rect.width + 'px;height:' + rect.height + 'px;';
                document.body.appendChild(offscreen);

                const tempChart = echarts.init(offscreen, null, { renderer: 'canvas' });
                opt.backgroundColor = '#0f0f1a';
                tempChart.setOption(opt);

                await new Promise(function(r) { setTimeout(r, 150); });

                const dataUrl = tempChart.getDataURL({ type: 'png', pixelRatio: 2, backgroundColor: '#0f0f1a' });
                const res = await fetch(dataUrl);
                const blob = await res.blob();
                await navigator.clipboard.write([new ClipboardItem({ 'image/png': blob })]);

                tempChart.dispose();
                document.body.removeChild(offscreen);

                btn.textContent = 'Copied!';
                btn.classList.add('copied');
                setTimeout(function() { btn.textContent = 'Copy'; btn.classList.remove('copied'); }, 2000);
            } catch (e) {
                btn.textContent = 'Failed';
                setTimeout(function() { btn.textContent = 'Copy'; }, 2000);
            }
        };

        // Data table
        const tableData = {{ data_table_json }};
        const tableColumns = {{ table_columns_json }};
        const tbody = document.getElementById('tableBody');

        function renderTable(data) {
            if (!tbody) return;
            const html = data.map(function(row) {
                return '<tr>' + tableColumns.map(function(col) {
                    const val = row[col];
                    return '<td title="' + String(val != null ? val : '').replace(/"/g, '&quot;') + '">' + (val != null ? val : '') + '</td>';
                }).join('') + '</tr>';
            }).join('');
            tbody.innerHTML = html;
        }
        renderTable(tableData);

        // Filter
        window.filterTable = function() {
            const query = document.getElementById('tableFilter').value.toLowerCase();
            if (!query) { renderTable(tableData); return; }
            const filtered = tableData.filter(function(row) {
                return tableColumns.some(function(col) {
                    return String(row[col] != null ? row[col] : '').toLowerCase().indexOf(query) !== -1;
                });
            });
            renderTable(filtered);
        };

        // Sort
        let sortCol = -1, sortAsc = true;
        window.sortTable = function(colIdx) {
            if (sortCol === colIdx) { sortAsc = !sortAsc; } else { sortCol = colIdx; sortAsc = true; }
            const col = tableColumns[colIdx];
            const sorted = tableData.slice().sort(function(a, b) {
                let va = a[col], vb = b[col];
                if (va == null) va = '';
                if (vb == null) vb = '';
                if (!isNaN(va) && !isNaN(vb)) { va = Number(va); vb = Number(vb); }
                if (va < vb) return sortAsc ? -1 : 1;
                if (va > vb) return sortAsc ? 1 : -1;
                return 0;
            });
            renderTable(sorted);
            // Update sort arrows
            document.querySelectorAll('.data-table th').forEach(function(th, i) {
                th.classList.toggle('sorted', i === colIdx);
                th.querySelector('.sort-arrow').textContent = (i === colIdx) ? (sortAsc ? '↑' : '↓') : '↕';
            });
        };
    })();
    </script>
</body>
</html>
