* { margin: 0; padding: 0; box-sizing: border-box; }

:root {
    --bg: #0f0f1a;
    --card-bg: rgba(255,255,255,0.04);
    --card-border: rgba(255,255,255,0.08);
    --text: #e0e0e0;
    --text-sub: #888;
    --accent: #667eea;
    --accent2: #764ba2;
    --glow: rgba(102,126,234,0.15);
}

body {
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    line-height: 1.6;
    padding: 24px;
    min-height: 100vh;
}

.dashboard-container {
    max-width: 1400px;
    margin: 0 auto;
}

/* Header */
.dashboard-header {
    text-align: center;
    margin-bottom: 24px;
    padding: 16px 24px;
    background: linear-gradient(135deg, rgba(102,126,234,0.1), rgba(118,75,162,0.1));
    border-radius: 12px;
    border: 1px solid var(--card-border);
}

.dashboard-header h1 {
    font-size: 20px;
    font-weight: 700;
    background: linear-gradient(135deg, #667eea, #f093fb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2px;
}

.dashboard-header .subtitle {
    color: var(--text-sub);
    font-size: 11px;
}

/* Smart Findings (narrative insights) */
.narrative-insights {
    display: flex;
    flex-direction: column;
    gap: 10px;
    margin-bottom: 24px;
}

.insight-card.narrative {
    border-left-width: 3px;
    font-size: 14px;
    padding: 14px 18px;
    background: rgba(102,126,234,0.06);
    border-left-color: #667eea;
}

.insight-card.narrative .insight-text {
    color: var(--text);
}

.insight-card.narrative.warning {
    background: rgba(245,87,108,0.06);
    border-left-color: #f5576c;
}

/* Insights */
.insight-card {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 12px 16px;
    border-radius: 8px;
    font-size: 13px;
    line-height: 1.5;
    background: rgba(255,255,255,0.03);
    border-left: 3px solid rgba(255,255,255,0.1);
}

.insight-card.highlight {
    border-left-color: #667eea;
    background: rgba(102,126,234,0.06);
}

.insight-card.warning {
    border-left-color: #f5576c;
    background: rgba(245,87,108,0.06);
}

.insight-icon { font-size: 16px; flex-shrink: 0; margin-top: 1px; }
.insight-text { color: var(--text-sub); }
.insight-card.highlight .insight-text { color: var(--text); }
.insight-card.warning .insight-text { color: var(--text); }

/* Chart description */
.chart-description {
    font-size: 12px;
    color: var(--text-sub);
    margin-bottom: 8px;
    padding: 6px 10px;
    background: rgba(102,126,234,0.05);
    border-radius: 4px;
    border-left: 2px solid rgba(102,126,234,0.3);
}

/* Section headers */
.section-title {
    font-size: 18px;
    font-weight: 600;
    color: var(--text);
    margin: 32px 0 16px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--card-border);
}

/* Chart cards */
.charts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(500px, 1fr));
    gap: 20px;
    margin-bottom: 24px;
}

.chart-card {
    background: var(--card-bg);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 20px;
    position: relative;
    overflow: hidden;
}

.chart-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, #667eea, #f093fb);
    opacity: 0.5;
}

.chart-card .chart-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.chart-card .chart-title {
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
}

.copy-btn {
    background: rgba(102,126,234,0.15);
    border: 1px solid rgba(102,126,234,0.3);
    color: #667eea;
    padding: 4px 12px;
    border-radius: 6px;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.2s;
}

.copy-btn:hover {
    background: rgba(102,126,234,0.25);
}

.copy-btn.copied {
    background: rgba(67,233,123,0.15);
    border-color: rgba(67,233,123,0.3);
    color: #43e97b;
}

.chart-area {
    width: 100%;
    height: 350px;
}

/* Stats sidebar for histograms */
.chart-with-stats {
    display: grid;
    grid-template-columns: 1fr 200px;
    gap: 16px;
    align-items: start;
}

.column-stats {
    font-size: 12px;
    color: var(--text-sub);
}

.column-stats dt {
    color: var(--text-sub);
    font-weight: 400;
    margin-top: 8px;
}

.column-stats dd {
    color: var(--text);
    font-weight: 600;
    font-size: 14px;
}

/* Full-width chart cards */
.chart-card.full-width {
    grid-column: 1 / -1;
}

.chart-area.tall {
    height: 500px;
}

/* Data table */
.table-container {
    overflow-x: auto;
    margin-top: 16px;
    border-radius: 8px;
    border: 1px solid var(--card-border);
}

.table-filter {
    padding: 8px 16px;
    background: transparent;
    border: 1px solid var(--card-border);
    border-radius: 8px;
    color: var(--text);
    font-size: 13px;
    width: 300px;
    margin-bottom: 12px;
    outline: none;
}

.table-filter:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--glow);
}

table.data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
}

table.data-table thead {
    position: sticky;
    top: 0;
    z-index: 1;
}

table.data-table th {
    background: rgba(102,126,234,0.1);
    color: var(--text);
    padding: 10px 12px;
    text-align: left;
    font-weight: 600;
    cursor: pointer;
    white-space: nowrap;
    user-select: none;
    border-bottom: 1px solid var(--card-border);
}

table.data-table th:hover {
    background: rgba(102,126,234,0.2);
}

table.data-table th .sort-arrow {
    margin-left: 4px;
    opacity: 0.4;
}

table.data-table th.sorted .sort-arrow {
    opacity: 1;
    color: var(--accent);
}

table.data-table td {
    padding: 8px 12px;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    color: var(--text-sub);
    max-width: 250px;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

table.data-table tbody tr:hover {
    background: rgba(255,255,255,0.03);
}

/* Footer */
.dashboard-footer {
    text-align: center;
    padding: 24px;
    margin-top: 40px;
    color: var(--text-sub);
    font-size: 12px;
}

.dashboard-footer a {
    color: var(--accent);
    text-decoration: none;
}

/* Responsive */
@media (max-width: 768px) {
    .charts-grid { grid-template-columns: 1fr; }
    .chart-with-stats { grid-template-columns: 1fr; }
    body { padding: 12px; }
}
